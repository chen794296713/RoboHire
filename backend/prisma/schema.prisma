generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String            @id @default(cuid())
  email                    String            @unique
  passwordHash             String?
  name                     String?
  company                  String?
  avatar                   String?
  provider                 String?
  providerId               String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  currentPeriodEnd         DateTime?
  interviewsUsed           Int               @default(0)
  resumeMatchesUsed        Int               @default(0)
  stripeCustomerId         String?           @unique
  subscriptionId           String?
  subscriptionStatus       String            @default("active")
  subscriptionTier         String            @default("free")
  topUpBalance             Float             @default(0)
  trialEnd                 DateTime?
  role                     String            @default("user")
  customMaxInterviews      Int?
  customMaxMatches         Int?
  adminAdjustmentsMade     AdminAdjustment[] @relation("AdminAdjustmentsMade")
  adminAdjustmentsReceived AdminAdjustment[] @relation("AdminAdjustmentsReceived")
  apiKeys                  ApiKey[]
  apiRequestLogs           ApiRequestLog[]
  usageRecords             ApiUsageRecord[]
  hiringRequests           HiringRequest[]
  hiringSessions           HiringSession[]
  llmCallLogs              LLMCallLog[]
  paymentRecords           PaymentRecord[]
  Resume                   Resume[]
  sessions                 Session[]
  topUpRecords             TopUpRecord[]

  @@index([email])
  @@index([provider, providerId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model HiringRequest {
  id             String         @id @default(cuid())
  userId         String
  title          String
  requirements   String
  jobDescription String?
  status         String         @default("active")
  webhookUrl     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  candidates     Candidate[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ResumeJobFit   ResumeJobFit[]

  @@index([userId])
  @@index([status])
}

model Candidate {
  id               String        @id @default(cuid())
  hiringRequestId  String
  name             String
  email            String
  resumeText       String
  matchScore       Int?
  status           String        @default("pending")
  evaluationReport Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  hiringRequest    HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)

  @@index([hiringRequestId])
  @@index([status])
  @@index([email])
}

model HiringSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json     @default("[]")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ApiKey {
  id           String           @id @default(cuid())
  userId       String
  name         String
  key          String           @unique
  prefix       String
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  scopes       String[]         @default(["read", "write"])
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs  ApiRequestLog[]
  usageRecords ApiUsageRecord[]

  @@index([key])
  @@index([userId])
}

model ApiUsageRecord {
  id               String   @id @default(cuid())
  userId           String
  apiKeyId         String?
  requestId        String?
  endpoint         String
  method           String
  statusCode       Int      @default(200)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  model            String?
  provider         String?
  durationMs       Int      @default(0)
  createdAt        DateTime @default(now())
  apiKey           ApiKey?  @relation(fields: [apiKeyId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
}

model ApiRequestLog {
  id               String       @id @default(cuid())
  requestId        String?
  userId           String?
  apiKeyId         String?
  endpoint         String
  method           String
  module           String
  apiName          String
  statusCode       Int          @default(200)
  durationMs       Int          @default(0)
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  llmCalls         Int          @default(0)
  cost             Float        @default(0)
  provider         String?
  model            String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime     @default(now())
  requestPayload   Json?
  responsePayload  Json?
  apiKey           ApiKey?      @relation(fields: [apiKeyId], references: [id])
  user             User?        @relation(fields: [userId], references: [id])
  llmCallLog       LLMCallLog[]

  @@index([requestId])
  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([apiName])
  @@index([provider])
  @@index([model])
  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([apiName, createdAt])
}

model LLMCallLog {
  id               String         @id @default(cuid())
  requestId        String?
  apiRequestLogId  String?
  userId           String?
  endpoint         String
  module           String
  provider         String
  model            String
  promptTokens     Int            @default(0)
  completionTokens Int            @default(0)
  totalTokens      Int            @default(0)
  cost             Float          @default(0)
  durationMs       Int            @default(0)
  createdAt        DateTime       @default(now())
  apiRequestLog    ApiRequestLog? @relation(fields: [apiRequestLogId], references: [id])
  user             User?          @relation(fields: [userId], references: [id])

  @@index([requestId])
  @@index([apiRequestLogId])
  @@index([userId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([provider])
  @@index([model])
  @@index([module, createdAt])
}

model TopUpRecord {
  id                  String    @id @default(cuid())
  userId              String
  stripeSessionId     String    @unique
  stripePaymentIntent String?   @unique
  amountCents         Int
  amountDollars       Float
  status              String    @default("pending")
  creditedAt          DateTime?
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSessionId])
  @@index([stripePaymentIntent])
}

model PaymentRecord {
  id            String    @id @default(cuid())
  userId        String
  outTradeNo    String    @unique
  amount        Float
  currency      String    @default("CNY")
  paymentMethod String
  tier          String?
  status        String    @default("pending")
  tradeNo       String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  metadata      Json?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([outTradeNo])
  @@index([status])
}

model AdminAdjustment {
  id        String   @id @default(cuid())
  userId    String
  adminId   String
  type      String
  amount    Float?
  oldValue  String?
  newValue  String?
  reason    String
  createdAt DateTime @default(now())
  admin     User     @relation("AdminAdjustmentsMade", fields: [adminId], references: [id], onDelete: Cascade)
  user      User     @relation("AdminAdjustmentsReceived", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model Resume {
  id              String         @id
  userId          String
  name            String
  email           String?
  phone           String?
  currentRole     String?
  experienceYears String?
  resumeText      String
  parsedData      Json?
  insightData     Json?
  jobFitData      Json?
  fileName        String?
  fileSize        Int?
  fileType        String?
  contentHash     String?
  status          String         @default("active")
  source          String         @default("upload")
  tags            String[]       @default([])
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  User            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ResumeJobFit    ResumeJobFit[]

  @@unique([userId, contentHash])
  @@index([contentHash])
  @@index([createdAt])
  @@index([name])
  @@index([userId])
  @@index([userId, status])
}

model ResumeJobFit {
  id              String        @id
  resumeId        String
  hiringRequestId String
  fitScore        Int?
  fitGrade        String?
  fitData         Json?
  pipelineStatus  String        @default("matched")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  HiringRequest   HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  Resume          Resume        @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, hiringRequestId])
  @@index([fitScore])
  @@index([hiringRequestId])
  @@index([pipelineStatus])
  @@index([resumeId])
}
